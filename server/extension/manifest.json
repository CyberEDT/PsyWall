{
    "manifest_version": 3,
    "name": "Cognitive Firewall",
    "version": "1.0.0",
    "description": "Real-time psychological manipulation detection for digital content.",
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icons/icon128.png"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "contentScript.js"
            ]
        }
    ],
    "host_permissions": [
        "http://localhost:3001/*"
    ]
}